{
  "name": "risu-workspace-tools",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "risu-workspace-tools": "./dist/cli/main.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "prepare": "npm run build",
    "check": "tsc -p tsconfig.json --noEmit",
    "format": "prettier --write .",
    "test": "npm run build && node tests/roundtrip-smoke.mjs --synthetic-only",
    "test:manifest": "npm run build && node tests/roundtrip-smoke.mjs --require-manifest",
    "test:all": "npm run build && node tests/roundtrip-smoke.mjs",
    "cli": "node dist/cli/main.js",
    "interactive": "node dist/cli/interactive.js",
    "build:exe": "bun build src/cli/main.ts --compile --outfile dist/risupack.exe --target bun-windows-x64"
  },
  "dependencies": {
    "adm-zip": "^0.5.16",
    "commander": "^12.1.0",
    "msgpackr": "^1.11.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.7",
    "@types/node": "^24.5.2",
    "prettier": "^3.6.2",
    "typescript": "^5.9.2"
  }
}
